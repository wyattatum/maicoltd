<!DOCTYPE html>
<html>
<head>
  <title>Login</title>
</head>
<body>

  <h2>Login Form</h2>

  <form action="/login" method="POST">
    <input type="text" name="username" placeholder="Enter username" required />
    <br><br>
    <input type="password" name="password" placeholder="Enter password" required />
    <br><br>
    <button type="submit">Login</button>
  </form>

</body>
</html>
